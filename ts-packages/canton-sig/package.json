{
  "name": "canton-sig",
  "version": "0.0.1",
  "description": "MPC-based ERC-20 custody service for Canton",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && cp ../../daml-packages/signet-vault-v1/.daml/dist/signet-vault-v1-0.0.2.dar dist/",
    "check:types": "tsc --noEmit",
    "prepack": "pnpm run build",
    "release": "pnpm run build && pnpm publish --access public",
    "release:beta": "pnpm run build && pnpm publish --access public --tag beta",
    "test": "vitest run",
    "reprice": "pnpm dlx tsx scripts/reprice-fee.ts"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "dependencies": {
    "@daml/types": "^3.4.11",
    "@mojotech/json-type-validation": "^3.1.0",
    "@noble/curves": "^2.0.1",
    "openapi-fetch": "^0.17.0",
    "signet.js": "0.4.1"
  },
  "devDependencies": {
    "@daml.js/signet-signer-v1-0.0.1": "file:./generated/model/signet-signer-v1-0.0.1",
    "@daml.js/signet-vault-v1-0.0.2": "file:./generated/model/signet-vault-v1-0.0.2",
    "@daml.js/signet-api-fee-v1-1.0.0": "file:./generated/model/signet-api-fee-v1-1.0.0",
    "@daml.js/signet-fee-amulet-0.0.1": "file:./generated/model/signet-fee-amulet-0.0.1",
    "@types/node": "^25.3.0",
    "viem": "^2.46.3",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
