claimTestRequestId = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"

-- DER signature over computeResponseHash(claimTestRequestId, errorPrefixMpcOutput) — refund case
refundTestSignature : Signature
refundTestSignature = ecdsaTestSig "3045022100bb8e3521b36754e8603a28510bd49f0b716ea4f264033ae4610fc2d01c81004a02205ca7a3482080bc49f8ee63ce438e71f63301cff3614234cad9e74086e8de3205"

-- DER signature over computeResponseHash(claimTestRequestId, boolFalseMpcOutput) — transfer returned false
boolFalseTestSignature : Signature
boolFalseTestSignature = EcdsaSig (EcdsaSigData with
  der = "30440220138d9f41f9d65fcf591b3914e9368beebb25de83406b5319ce198feb9302312a022065fa8342c5ef82f7f7c81bf9f43585cf3528eb6ad2390100ba74a177be79e74c"
  recoveryId = 1)

