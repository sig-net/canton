# ─────────────────────────────────────────────────────────────────────────────
# Canton DevNet e2e — ERC-20 Vault deposit + withdraw (src/test/live-e2e.test.ts)
#
# Runs ONLY when MPC_CANTON_LIVE_MUTATE=1 (it mutates the live ledger and spends
# DevNet funds). See ../TEST_LOCALLY.md for the
# local-sandbox alternative (Rust mpc repo).
#
# This is the DevNet template. Deploy is network-aware: for testnet use .env.testnet via
#   CANTON_NETWORK=testnet DOTENV_CONFIG_PATH=.env.testnet DEPLOY_CONFIRM=1 \
#     pnpm exec tsx src/scripts/deploy.ts
# ─────────────────────────────────────────────────────────────────────────────

# Canton DevNet JSON Ledger API + OIDC (client-credentials) auth.
MPC_CANTON_JSON_API_URL=https://ledger.dev.sig.network
MPC_CANTON_OIDC_TOKEN_URL=https://sig-network-canton-dev.eu.auth0.com/oauth/token
MPC_CANTON_OIDC_CLIENT_ID=...
MPC_CANTON_OIDC_CLIENT_SECRET=...
MPC_CANTON_OIDC_AUDIENCE=https://canton.network.global
MPC_CANTON_OIDC_SCOPE=                       # leave unset on dev (empty scope)

# On DevNet a single party is operators + requester + sigNetwork (the MPC's own party).
MPC_CANTON_LEDGER_API_USER=...@clients
MPC_CANTON_PARTY_ID=signet-dev-1::1220...

# Signer + Vault disclosures — fetched from the disclosure endpoint
# (apps/disclosure-api; no secret), the way a real integrator obtains the sigNetwork-only
# contracts it can't read in its own ACS. This is the only disclosure config the e2e needs.
# DevNet is not on the integrator surface, so its feed lives under /api/internal/.
MPC_CANTON_DISCLOSURE_API_URL=https://disclosure-api.vercel.app/api/internal/devnet

# MPC cluster root pubkey — NAJ (secp256k1:base58…) or uncompressed
# SEC1 (04 + 128 hex). Used to derive deposit/vault addresses. Get it from the deployment.
MPC_CANTON_ROOT_PUBLIC_KEY=04...

# CC signature fee (charged on every RequestDeposit / RequestWithdrawal). Free by default
# (the deployed FeePriceConfig has feeAmount 0). For a paid run, deploy a non-zero config
# with deploy.ts (DEPLOY_CONFIRM=1 MPC_CANTON_FEE_AMOUNT=0.01) and set the registry.
# The token-standard registry resolves the CC TransferFactory for the fee transfer. On
# DevNet use the validator's scan-proxy (the SV scan is IP-locked); it requires the same
# OIDC bearer as the ledger. Only consulted in paid mode (feeAmount > 0).
MPC_CANTON_CC_REGISTRY_URL=https://wallet.dev.sig.network/api/validator/v0/scan-proxy
# MPC_CANTON_SIG_NETWORK_FA_PARTY_ID=...::1220...  # fee admin (Signer.sigNetworkFA); defaults to MPC_CANTON_PARTY_ID

# Sepolia RPC. The Vault hardcodes caip2 eip155:1 (decoupled from the signed chainId),
# so the test signs txs with the Sepolia chainId (11155111) and broadcasts them
# here; the MPC's eip155:1 indexer watches this chain. (Mainnet needs no such trick —
# chainId 1 already maps to caip2 eip155:1.)
MPC_CANTON_ETH_RPC_URL=https://sepolia.infura.io/v3/<INFURA_KEY>
FAUCET_PRIVATE_KEY=0x...                      # 0x + 64 hex; funds the derived deposit/vault addresses
# ERC20_ADDRESS=0xB4F1737Af37711e9A5890D9510c9bB60e170CB0D   # optional; defaults to test USDC

# Opt-in + tuning
# MPC_CANTON_LIVE_MUTATE=1                     # REQUIRED to run (spends funds)
# MPC_CANTON_RESPOND_TIMEOUT_MS=1200000       # outcome-leg wait (default 20 min)
# MPC_CANTON_BROADCAST_DELAY_MS=20000         # delay before broadcasting (default 20s)
